    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "mcp:external": "node --import tsx src/mcp/external/server.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opennextjs/cloudflare": "^1.0.0",

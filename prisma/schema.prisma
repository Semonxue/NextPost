generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  engineType      = "wasm"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String @id @default(cuid())
  username String   @unique
  password  String
  email     String?
  aiProvider String  @default("openai")
  aiApiKey   String?
  aiModel   String   @default("gpt-4")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  accounts     Account[]
  posts Post[]
  media Media[]
  conversations Conversation[]
  externalApiKeys ExternalApiKey[]
  aiOperationLogs AiOperationLog[]
}

model Platform {
  id String   @id @default(cuid())
  name      String   @unique
  icon      String?
  createdAt DateTime @default(now())
  
  accounts Account[]
  config   PlatformConfig?
}

model PlatformConfig {
  id                String   @id @default(cuid())
  platformId        String   @unique
  maxContentLength  Int      @default(280)
  maxImages         Int      @default(4)
  maxVideos         Int      @default(1)
  allowMixedMedia   Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  platform Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)
}

model Account {
  id          String   @id @default(cuid())
  userId      String
  platformId  String
  name String
  handle String
  description String?
  
  deletedAt  DateTime?
  deletedBy  String?
  deleteNote String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform Platform @relation(fields: [platformId], references: [id])
  
  posts Post[]
  
  @@index([deletedAt])
  @@index([userId])
}

model Post {
  id            String   @id @default(cuid())
  userId        String
  accountId     String
  content String
  title  String?
  mediaUrls     String   @default("[]")
  mediaThumbnails String @default("[]")
  scheduledTime DateTime?
  timezone String   @default("Asia/Shanghai")
  status        String   @default("draft")
  
  publishToken     String?
  publishTokenExp  DateTime?
  publishedAt      DateTime?
  externalPostId   String?
  externalPostUrl  String?
  publishError     String?
  publishAttempts  Int      @default(0)
  
  deletedAt  DateTime?
  deletedBy  String?
  deleteNote String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  user User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  @@index([status])
  @@index([scheduledTime])
  @@index([deletedAt])
  @@index([userId])
}

model Media {
  id        String   @id @default(cuid())
  userId    String
  type String
  url       String
  thumbnailUrl String?
  filename String
  size      Int
  mimeType  String
  uploadedAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  title String   @default("新对话")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String
  toolCalls      String   @default("[]")
  toolResults String   @default("[]")
  model          String?
  createdAt      DateTime @default(now())
  
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model ExternalApiKey {
  id          String    @id @default(cuid())
  userId      String
  name        String
  key         String    @unique
  permissions String    @default("read_report")
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([key])
}

model AiOperationLog {
  id             String   @id @default(cuid())
  userId         String
  conversationId String?
  operation      String
  entityType     String
  entityId       String
  beforeState    String?
  afterState     String?
  aiModel        String?
  createdAt      DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}